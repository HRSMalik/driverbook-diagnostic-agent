OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Shared secret between the main backend and this service.
# The main backend sends this in every request as: X-API-Key: <value>
# /health and /ready are exempt (used by container health checks).
API_KEY=change-me-use-a-long-random-string

# Max requests per 60-second window per API key. Default: 60.
RATE_LIMIT_PER_MINUTE=60
